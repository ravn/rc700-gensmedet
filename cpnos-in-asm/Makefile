# Makefile for cpnos-in-asm — pure-Z80-asm CP/NOS slave (PROM1-fit target).
#
# Status: scaffold only.  Bring-up is the next session's work.
# Default target prints a not-yet-implemented message rather than
# silently doing nothing, so anyone running `make` here gets oriented.

SHARED ?= ../cpnos-shared

.PHONY: all help status
all: status

status:
	@echo "cpnos-in-asm: scaffold only.  No asm sources yet."
	@echo
	@echo "See README.md for the bring-up plan."
	@echo
	@echo "Shared assets available at:"
	@echo "  $(SHARED)/docs/CPNET_WIRE_PROTOCOL.md"
	@echo "  $(SHARED)/include/payload_header.h"
	@echo "  $(SHARED)/include/cfgtbl.h"
	@echo "  $(SHARED)/mame/polypascal_test.lua  (4-cell test oracle)"
	@echo "  $(SHARED)/scripts/                  (image-stitch helpers)"
	@exit 0

help:
	@echo "cpnos-in-asm targets:"
	@echo "  make            - status (this scaffold message)"
	@echo "  make help       - this help"
	@echo
	@echo "Bring-up not yet implemented.  See README.md."
